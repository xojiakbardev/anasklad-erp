# --- Backend ---
APP_ENV=development
APP_NAME=anasklad

DATABASE_URL=postgresql+asyncpg://anasklad:anasklad_pass@localhost:5432/anasklad
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change_me_to_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=30

# Fernet key for encrypting Uzum tokens at rest (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIALS_FERNET_KEY=

CORS_ORIGINS=http://localhost:5173

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=anasklad-api

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_SENTRY_DSN=
